# 服务端口
PORT=3000

# 数据库类型: mysql | sqlite
DB_TYPE=sqlite

# --- MySQL 配置（DB_TYPE=mysql 时生效）---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=password
DB_NAME=fminfinity

# --- SQLite 配置（DB_TYPE=sqlite 时生效）---
# SQLite 数据库文件存储路径（相对于 Server 目录）
DB_SQLITE_PATH=./main.sqlite

# JWT 密钥（生产环境请使用随机生成的强密钥）
# 生成方式: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
